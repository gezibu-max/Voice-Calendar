# 后端环境配置示例
# 复制本文件为 .env 后填入实际值即可被 pydantic-settings 读取

APP_NAME=voice-calendar-backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# CORS 允许的前端来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000

# SQLite 文件路径（相对 backend/ 目录）
DATABASE_URL=sqlite:///./data/voice_calendar.db

# ---- 大模型配置（用于语音文字解析） ----
# 默认走 DeepSeek。换其它 OpenAI 兼容服务时只需改 base_url + model
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=30
