#### 5.2.3 拖拽交互

**功能**：支持拖拽事件调整时间位置

```typescript
// hooks/useDragDrop.ts
export function useDragDrop() {
    const dragState = useRef<{
        event: Event;
        startY: number;
        originalStart: Date;
    } | null>(null);

    const handleDragStart = (e: React.MouseEvent, event: Event) => {
        dragState.current = {
            event,
            startY: e.clientY,
            originalStart: new Date(event.startTime)
        };
    };

    const handleDragMove = (e: React.MouseEvent) => {
        if (!dragState.current) return;
        // 计算位置偏移，更新事件显示
    };

    const handleDragEnd = (e: React.MouseEvent) => {
        if (!dragState.current) return;
        // 计算新时间，触发更新回调
    };

    return { handleDragStart, handleDragMove, handleDragEnd };
}
```

